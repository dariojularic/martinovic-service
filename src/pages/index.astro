---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Handwerker & Gartenservice München | Martinovic Service"
  description="Ihr zuverlässiger Handwerker- und Gartenservice in München. Möbelmontage, Küchenmontage und professionelle Gartenpflege - alles aus einer Hand. Jetzt kostenlos anfragen!"
>
  <main>
    <section class="hero-section">
      <div class="container hero-grid">
        <div
          class="hero-content hero-content-home order-mobile-2 order-desktop-1"
        >
          <h1 class="hero-title hero-title-home">
            Handwerker- und Garten<br /><span class="text-primary">Service</span
            > in Müchen
          </h1>

          <p class="hero-text">
            Professionelle Handwerker- und Gartendienstleistungen in München -
            von Krunoslav Martinovic. Qualitätshandwerk, das Sie für jede Ecke
            Ihres Zuhause und Gartens überzeugt.
          </p>

          <div class="hero-actions">
            <a href="#contact" class="btn btn-primary btn-lg">
              Jetzt Anrufen
            </a>
            <a href="#testimonials" class="btn btn-secondary btn-lg">
              Fotos Ansehen
            </a>
          </div>
        </div>

        <div class="hero-image-side order-mobile-1 order-desktop-2">
          <div class="hero-image-wrapper">
            <div
              class="hero-bg-img"
            >
            <img src="/images/hero.webp" alt="">
            </div>

            <!-- <div class="hero-float-card">
              <div class="float-icon">
                <span class="material-symbols-outlined">schedule</span>
              </div>
              <div>
                <p
                  style="font-size: 0.875rem; font-weight: 700; margin-bottom: 0.1rem;"
                >
                  Fast Turnaround
                </p>
                <p style="font-size: 0.75rem; color: #68797d;">
                  Most repairs finished in 24h
                </p>
              </div>
            </div> -->
          </div>
        </div>
      </div>
    </section>

    <section class="section-padding bg-white" id="services">
      <div class="container">
        <div class="section-header">
          <div>
            <span class="section-eyebrow">Leistungsübersicht</span>
            <h3 class="section-heading">
              Umfassende Lösungen für Innen und Außen
            </h3>
          </div>
          <!-- <a href="#" class="link-arrow">
            View all services <span class="material-symbols-outlined"
              >trending_flat</span
            >
          </a> -->
        </div>

        <div class="services-grid">
          <a href="/möbelmontage">
            <div class="service-card">
              <div class="service-card-wrapper">
                <img
                  class="service-card-img"
                  src="/images/möbelmontage.webp"
                  alt="Kitchen assembly"
                />

                <div class="service-card-overlay"></div>

                <div class="service-card-content">
                  <div class="service-icon-box">
                    <span
                      class="material-symbols-outlined"
                      style="font-size: 2rem;">construction</span
                    >
                  </div>

                  <div class="service-card-text">
                    <h4 class="service-title">Möbelmontage</h4>
                    <p class="text-muted" style="font-size: 0.875rem;">
                      Professioneller Aufbau aller Marken und Modelle - von
                      einfachen Regalen bis hin zu komplexen Kleiderschränken.
                      Schnell, sauber und ohne Stress für Sie.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </a>

          <a href="/küchenmontage">
            <div class="service-card">
              <div class="service-card-wrapper">
                <img
                  class="service-card-img"
                  src="/images/küchenmontage.webp"
                  alt="Kitchen assembly"
                />

                <div class="service-card-overlay"></div>

                <div class="service-card-content">
                  <div class="service-icon-box">
                    <span
                      class="material-symbols-outlined"
                      style="font-size: 2rem;">construction</span
                    >
                  </div>
                  <div class="service-card-text">
                    <h4 class="service-title">Küchenmontage</h4>
                    <p class="text-muted" style="font-size: 0.875rem;">
                      Fachgerechte Montage Ihrer neuen Küche in München. Ob
                      Ikea, Nobilia oder andere Hersteller - wir sorgen für
                      millimetergenaue Ausrichtung und ein perfektes Ergebnis.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </a>

          <a href="/gartenpflege">
            <div class="service-card">
              <div class="service-card-wrapper">
                <img
                  class="service-card-img"
                  src="/images/gartenpflege.webp"
                  alt="Kitchen assembly"
                />

                <div class="service-card-overlay"></div>

                <div class="service-card-content">
                  <div class="service-icon-box">
                    <span
                      class="material-symbols-outlined"
                      style="font-size: 2rem;">construction</span
                    >
                  </div>
                  <div class="service-card-text">
                    <h4 class="service-title">Gartenpflege</h4>
                    <p class="text-muted" style="font-size: 0.875rem;">
                      Regelmäßige Gartenpflege und Gartengestaltung in München.
                      Rasenmähen, Heckenschnitt, Bepflanzung und saisonale
                      Gartenarbeiten - alles aus einer Hand.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </a>

          <a href="/hausreparaturen ">
            <div class="service-card">
              <div class="service-card-wrapper">
                <img
                  class="service-card-img"
                  src="/images/hausreparaturen.webp"
                  alt="Kitchen assembly"
                />

                <div class="service-card-overlay"></div>

                <div class="service-card-content">
                  <div class="service-icon-box">
                    <span
                      class="material-symbols-outlined"
                      style="font-size: 2rem;">construction</span
                    >
                  </div>
                  <div class="service-card-text">
                    <h4 class="service-title">
                      Hausreparaturen
                    </h4>
                    <p class="text-muted" style="font-size: 0.875rem;">
                      Kleine Reparaturen, Wartungsarbeiten und
                      Handwerkerleistungen in München - schnell, zuverlässing
                      und zu fairen Preisen.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="section-padding" id="about">
      <div class="container">
        <div class="section-header">
          <div>
            <span class="section-eyebrow">Über den Profi</span>
            <h3 class="section-heading">
              Persönlichen Service - ohne Subunternehmer
            </h3>
          </div>
        </div>

        <div class="about-grid">
          <div class="portrait-wrapper">
            <div class="portrait-frame">
              <div
                class="portrait-img"
              >
              <img src="/images/krunoslavmartinovic.webp" alt="">
              </div>
            </div>
            <div class="experience-badge">
              <span class="exp-number">7+</span>
              <span class="exp-label">Jahre Erfahrung</span>
            </div>
          </div>

          <div class="about-content">
            <p class="about-text">
              Ich bin Krunoslav Martinovic. Wenn Sie Martinovic Service buchen,
              bekommen Sie mich. Keine Subunternehmer, keine Missverständnisse –
              nur zuverlässige, ehrliche Arbeit, die pünktlich erledigt wird.
            </p>

            <a href="/über-mich" class="link-arrow">
              Mehr über mich <span class="material-symbols-outlined"
                >trending_flat</span
              >
            </a>

            <div class="checklist-grid">
              <div class="flex-center-v gap-2">
                <span class="material-symbols-outlined text-primary"
                  >check_circle</span
                >
                <span class="font-bold">Vollständig versichert</span>
              </div>
              <div class="flex-center-v gap-2">
                <span class="material-symbols-outlined text-primary"
                  >check_circle</span
                >
                <span class="font-bold">Transparente Preisgestaltung</span>
              </div>
              <div class="flex-center-v gap-2">
                <span class="material-symbols-outlined text-primary"
                  >check_circle</span
                >
                <span class="font-bold">Pünktlich und zuverlässig</span>
              </div>
              <div class="flex-center-v gap-2">
                <span class="material-symbols-outlined text-primary"
                  >check_circle</span
                >
                <span class="font-bold">Saubere Arbeitsweise</span>
              </div>
            </div>

            <div class="quote-box">
              <p class="text-main italic font-medium">
                "Mein Ziel ist einfach: Jedes Zuhause besser zu verlassen, als
                ich es vorgefunden habe – und jeden Kunden mit einem Lächeln."
              </p>
              <p
                style="margin-top: 1rem; font-size: 0.875rem; font-weight: 700;"
              >
                — Krunoslav Martinovic
              </p>
            </div>

            <div class="hero-actions">
              <a href="#contact" class="btn btn-primary btn-lg">
                Jetzt Anrufen
              </a>
              <a href="/über-mich" class="btn btn-secondary btn-lg">
                ÜBER UNS
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-padding bg-gray" id="testimonials">
      <div class="container">
        <div class="testimonials-header">
          <h3 class="section-heading">What your neighbors say</h3>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
