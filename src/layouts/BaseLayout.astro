    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>
      {title ?? "Handwerker & Gartenservice München | Martinovic Service"}
    </title>

    <meta
      name="description"
      content={description ??
        "Ihr zuverlässiger Handwerker- und Gartenservice in München. Möbelmontage, Küchenmontage und professionelle Gartenpflege - alles aus einer Hand. Jetzt kostenlos anfragen!"}
    />

